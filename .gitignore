# Big cached historical datasets — NOT needed in the cloud (live_scan fetches fresh data).
data/

# Python noise
__pycache__/
*.pyc

# Local Task Scheduler logs (scan/push runners)
_tasklogs/

# Non-scanner research families kept out of this crypto-scanner repo:
# F&O work is version-controlled in the nifty-condor-paper repo; equity research is local-only.
fno_*.py
fno_*.md
equity_*.py
deploy_*.py

# Commodity scanner transient runtime state (the record files — log + trade ledger — stay tracked)
results/commodity_scan_status.txt
results/commodity_scan_seen.json
results/commodity_paper_open.json
results/commodity_paper_summary.txt

# Backtest plot/CSV artifacts (keep results/live_scan_* — see negations below)
results/*.png
results/crypto*.csv
results/trade_log*.csv

# Keep the live-scan outputs (the whole point of the cloud runner)
!results/live_scan_log.csv
!results/live_scan_status.txt
!results/live_scan_seen.json
